{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {"open": "{", "close": "}"},
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "\"", "close": "\"", "notIn": ["string"]},
    {"open": "'", "close": "'", "notIn": ["string"]}
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!#).)*(:|\\{)\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*[\\}\\]]"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:cdef|cpdef|ctypedef|def|class|for|if|elif|else|while|try|with|finally|except|async).*:\\s*$",
      "action": {"indentAction": "indent"}
    }
  ]
}
